---
layout: default
---
<div class="post">
  <article>
    <div class="row align-items-start">
      <!-- Left column -->
      <div class="col-sm-4 text-center">
        <img
          class="img-fluid z-depth-1 rounded-circle"
          src="{{ 'assets/img/prof_pic.jpg' | relative_url }}"
          alt="profile picture"
          style="width: 190px; max-width: 100%; margin-bottom: 1rem;"
        >

        <header class="post-header" style="margin-bottom: 1rem;">
          <h1 class="post-title" style="margin-bottom: 1rem; font-weight: 700;">
            Yang Long
          </h1>
          <p class="desc" style="margin-bottom: 0.15rem; font-size: 1rem;">
            Statistics PhD Candidate
          </p>
          <p class="desc" style="margin-bottom: 0; font-size: 1rem;">
            George Mason University
          </p>
        </header>

        <div class="social" style="margin-top: 1.25rem;">
          <div class="contact-icons">
            <hr style="margin-bottom: 1rem; max-width: 230px;">
            <a href="mailto:ylong5@gmu.edu"
              style="margin-right: 0.35em; text-decoration: none; border-bottom: none; box-shadow: none;"
              rel="external nofollow noopener" target="_blank">
              <i class="fas fa-envelope fa-sm"></i>
            </a>
            <a href="https://scholar.google.com/citations?hl=en&user=tNDSj5IAAAAJ"
              style="margin-right: 0.35em; text-decoration: none; border-bottom: none; box-shadow: none;"
              rel="external nofollow noopener" target="_blank">
              <i class="fab fa-google fa-xs"></i>
            </a>
            <a href="https://www.linkedin.com/in/ylong5"
              title="LinkedIn"
              style="margin-right: 0.35em; text-decoration: none; border-bottom: none; box-shadow: none;"
              rel="external nofollow noopener" target="_blank">
              <i class="fab fa-linkedin fa-sm"></i>
            </a>
            <a href="https://github.com/ylong-chn"
              title="GitHub"
              style="margin-right: 0.35em; text-decoration: none; border-bottom: none; box-shadow: none;"
              rel="external nofollow noopener" target="_blank">
              <i class="fab fa-github fa-sm"></i>
            </a>
            <a href="{{ '/assets/pdf/resume_YL.pdf' | relative_url }}"
              title="CV"
              style="text-decoration: none; border-bottom: none; box-shadow: none;"
              rel="external nofollow noopener" target="_blank">
              <i class="ai ai-cv"></i>
            </a>
          </div>
        </div>
        <div style="height:60px;font-size:1px;">&nbsp;</div>
      </div>

      <!-- Right column -->
      <div class="col-sm-8">
        <div class="clearfix" style="padding-top: 0.5rem;">
          {{ content }}
        </div>
      </div>
    </div>

    <!-- News -->
    {% if page.news and site.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">news</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}
  </article>
</div>